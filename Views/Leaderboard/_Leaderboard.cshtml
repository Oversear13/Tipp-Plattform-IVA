@model LeaderboardViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leaderboard</title>

    <!-- CSS-Dateien -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/btn.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/input.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/table.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navtabs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TippPlattform.styles.css" asp-append-version="true" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700&display=swap">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

</head>


<body>
    <div class="tippabgabe-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th>Position</th>
                    <th>Name</th>
                    <th>Punkte</th>
                    <th>Gesamt</th>
                    @foreach (var lastgamesHome in Model.LastGames)
                    {
                        <th>
                            <div class="game-result">
                                <div class="team-result">
                                    <div class="team-name">@lastgamesHome.TeamA</div>
                                    <div class="team-score">@lastgamesHome.TeamAScore</div>
                                </div>
                                <div class="team-result">
                                    <div class="team-name">@lastgamesHome.TeamB</div>
                                    <div class="team-score">@lastgamesHome.TeamBScore</div>
                                </div>
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    int pos = 1;
                }
                @foreach (var user in Model.Leaderboard)
                {
                    <tr>
                        <td>
                            @pos
                        </td>
                        <td>
                            @user.Username
                        </td>
                        <td>
                            @(user.LastTipp
                                .Where(x => Model.LastGames.Select(g => g.SpielId).Contains(x.SpielId))
                                .Select(x => x.UserGewinn)
                                .Sum())
                        </td>
                        <td>
                            @user.Points
                        </td>
                        @foreach(var spiel in Model.LastGames)
                        {
                            var tipp = user.LastTipp.FirstOrDefault(t => t.SpielId == spiel.SpielId);
                            if (tipp != null)
                            {
                                <td>@tipp.UserTipp <span style="color: var(--color-orange-base); margin-left: 16px;">@tipp.UserGewinn</span></td>
                            }
                            else
                            {
                                <td>- : - <span style="color: var(--color-orange-base); margin-left: 16px;">0</span></td>
                            }
                        }
                    </tr>
                    pos++;
                }
            </tbody>
        </table>
    </div>
</body>
</html>