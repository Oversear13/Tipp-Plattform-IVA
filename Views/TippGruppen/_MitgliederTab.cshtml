@model List<TippPlattform.Models.Beitritt>
@{
    var currentUserId = int.Parse(User.FindFirst("UserId").Value);
}

<!-- Mitglied einladen -->
<div class="mb-3">
    <button class="btn btn-primary" type="button" style="margin-bottom: 24px;"
            onclick="$('#einladeForm').toggle()">
        Mitglied hinzufügen <i class="bi bi-plus-lg"></i>
    </button>
</div>
<div id="einladeForm" style="display:none;">
    <form method="post" asp-controller="TippGruppen" asp-action="MitgliedEinladen">
        <div class="form-field" style="display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 24px; width: 400px;">
            <input type="hidden" name="gruppeId" value="@ViewBag.GruppeId" />
            <div class="input">
                <input type="text" name="userIdentifier" class="form-control" style="width: 600px;"
                       placeholder="Benutzername eingeben" required />

            </div>
            <button type="submit" class="btn btn-primary">Hinzufügen</button>
        </div>
    </form>
</div>

<!-- Mitgliederliste -->
@if (Model != null && Model.Any())
{

    <table class="table">
        <thead>
            <tr>
                <th>Benutzername</th>
                <th>Löschen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var beitritt in Model)
            {
                <tr>
                    <td>@beitritt.User.Username</td>
                    <td>
                        @if (beitritt.User.Id != currentUserId)
                        {
                            <button type="button" class="icon-btn" data-bs-toggle="modal" data-bs-target="#deleteModal_@beitritt.User.Id">
                                <i class="bi bi-trash-fill"></i>
                            </button>

                            <!-- Modal direkt hier -->
                            <div class="modal fade" id="deleteModal_@beitritt.User.Id" tabindex="-1" aria-labelledby="deleteModalLabel_@beitritt.User.Id" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <form method="post" asp-controller="TippGruppen" asp-action="MitgliedEntfernen">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="deleteModalLabel_@beitritt.User.Id">Mitglied entfernen</h5>
                                                <button type="button" class="icon-btn" data-bs-dismiss="modal" aria-label="Schließen">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Möchtest du <strong>@beitritt.User.Username</strong> wirklich entfernen?</p>
                                                <input type="hidden" name="gruppeId" value="@ViewBag.GruppeId" />
                                                <input type="hidden" name="userId" value="@beitritt.User.Id" />
                                                <div class="d-flex justify-content-between mt-3">
                                                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal">Abbrechen</button>
                                                    <button type="submit" class="btn btn-danger">Entfernen</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button type="button" class="icon-btn" disabled>
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">Es sind keine Mitglieder vorhanden.</div>
}


@section Scripts {
    <script>

    </script>
}