@model TippPlattform.Models.ViewModels.MitgliederVerwaltungViewModel

@{
    ViewData["Title"] = "Mitgliederverwaltung";
}

<h2>Mitglieder verwalten</h2>

<a asp-action="MitgliedEinladen" asp-route-gruppeId="@Model.GruppeId" class="btn btn-success mb-3">Mitglied einladen +</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>E-Mail</th>
            <th>Rolle</th>
            <th>Löschen</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model.Mitglieder)
        {
            <tr>
                <td>@m.Name</td>
                <td>@m.Email</td>
                <td>
                    <form asp-action="ÄndereRolle" method="post" class="d-flex align-items-center">
                        <input type="hidden" name="gruppeId" value="@Model.GruppeId" />
                        <input type="hidden" name="userId" value="@m.UserId" />
                        <select name="neueRolle" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                            <option value="Spieler" selected="@((m.Rolle == "Spieler") ? "selected" : null)">Spieler</option>
                            <option value="Gruppenbesitzer" selected="@((m.Rolle == "Gruppenbesitzer") ? "selected" : null)">Gruppenbesitzer</option>
                        </select>
                    </form>
                </td>
                <td>
                    @if (!m.IstBesitzer)
                    {
                        <form asp-action="EntferneMitglied" method="post" onsubmit="return confirm('Wirklich löschen?');">
                            <input type="hidden" name="gruppeId" value="@Model.GruppeId" />
                            <input type="hidden" name="userId" value="@m.UserId" />
                            <button type="submit" class="btn btn-danger btn-sm">🗑</button>
                        </form>
                    }
                    <form asp-action="MitgliedEinladen" method="post" class="mt-4">
                        <input type="hidden" name="gruppeId" value="@Model.GruppeId" />
                        <div class="form-group">
                            <label for="benutzername">Benutzername eingeben:</label>
                            <input type="text" class="form-control" name="benutzername" required />
                        </div>
                        <button type="submit" class="btn btn-primary mt-2">Einladen</button>
                    </form>

                    @if (TempData["InviteError"] != null)
                    {
                        <div class="alert alert-danger mt-2">@TempData["InviteError"]</div>
                    }
                    @if (TempData["InviteSuccess"] != null)
                    {
                        <div class="alert alert-success mt-2">@TempData["InviteSuccess"]</div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
