@{
    ViewData["Title"] = "FAQ";
}

<section class="hero">
    <h1>Häufig gestellte <span>Fragen</span></h1>
    <p>Hier findest du Antworten auf die wichtigsten Fragen rund um BUDDYBET. Falls deine Frage nicht dabei ist,
        kontaktiere uns gerne!</p>
</section>

<!-- FAQ Sections -->
<section id="erste-schritte" style="margin-bottom: 80px;">
    <h2>Erste Schritte</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie registriere ich mich bei BUDDYBET?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Die Registrierung ist ganz einfach: Klicke auf "Registrieren", gib deine E-Mail-Adresse, einen
                Benutzernamen und ein sicheres Passwort ein. Nach der Bestätigung deiner E-Mail-Adresse kannst du sofort
                loslegen!</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Ist BUDDYBET kostenlos?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Ja, BUDDYBET ist komplett kostenlos! Du kannst Tippgruppen erstellen, beitreten und tippen, ohne einen
                Cent zu bezahlen. Wir finanzieren uns nicht über Geldeinsätze, sondern wollen einfach den Spaß am
                gemeinsamen Tippen fördern.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie finde ich meine erste Tippgruppe?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Nach der Registrierung kannst du entweder eine eigene Tippgruppe erstellen oder einer bestehenden
                beitreten. Frage Freunde, ob sie bereits eine Gruppe haben, oder durchstöbere die öffentlichen Gruppen
                in deiner Region.</p>
        </div>
    </div>
</section>

<section id="tippgruppen" style="margin-bottom: 80px;">
    <h2>Tippgruppen</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie erstelle ich eine Tippgruppe?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Gehe zu "Tippgruppen" und klicke auf "Neue Gruppe erstellen". Wähle einen Namen, eine Beschreibung und
                die Sportart aus. Du kannst die Gruppe öffentlich machen oder mit einem Passwort schützen. Als Ersteller
                bist du automatisch Admin der Gruppe.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie viele Mitglieder kann eine Tippgruppe haben?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Eine Tippgruppe kann bis zu 50 Mitglieder haben. Das sorgt für spannende Konkurrenz, ohne dass die
                Übersicht verloren geht. Für größere Communities empfehlen wir, mehrere Untergruppen zu erstellen.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Kann ich mehreren Tippgruppen beitreten?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Absolut! Du kannst so vielen Tippgruppen beitreten, wie du möchtest. Tippe mit deinen Freunden, deiner
                Familie und deinen Kollegen - jede Gruppe hat ihre eigene Rangliste und ihre eigenen Spiele.</p>
        </div>
    </div>
</section>

<section id="tippen" style="margin-bottom: 80px;">
    <h2>Tippen</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Auf welche Spiele kann ich tippen?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Du kannst auf alle Spiele tippen, die in deiner Tippgruppe aktiviert sind. Dazu gehören die großen
                Fußball-Ligen (Bundesliga, Premier League, Champions League), Basketball-Ligen und viele weitere
                Sportarten. Der Gruppen-Admin entscheidet, welche Spiele verfügbar sind.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Bis wann kann ich meinen Tipp abgeben?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Du kannst deinen Tipp bis zum Anpfiff des jeweiligen Spiels abgeben oder ändern. Sobald das Spiel
                begonnen hat, werden die Tipps gesperrt. Wir senden dir Erinnerungen, damit du keine wichtigen Spiele
                verpasst!</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Was passiert, wenn ich einen Tipp vergesse?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Kein Problem! Wenn du einen Tipp verpasst, erhältst du einfach 0 Punkte für dieses Spiel. Das passiert
                jedem mal. Deine anderen Tipps bleiben davon unberührt, und du kannst bei den nächsten Spielen wieder
                voll durchstarten.</p>
        </div>
    </div>
</section>

<section id="punkte" style="margin-bottom: 80px;">
    <h2>Punkte & Ranglisten</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie funktioniert das Punktesystem?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Unser Punktesystem ist fair und einfach: 3 Punkte für das exakte Ergebnis, 1 Punkt für die richtige
                Tendenz (Sieg/Unentschieden/Niederlage). Bei manchen Turnieren gibt es Bonuspunkte für schwierigere
                Tipps. Jede Tippgruppe kann eigene Regeln festlegen.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie oft wird die Rangliste aktualisiert?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Die Rangliste wird in Echtzeit aktualisiert, sobald ein Spielergebnis feststeht. Du siehst sofort, wie
                sich deine Tipps auf deine Position auswirken. Push-Benachrichtigungen halten dich über wichtige
                Änderungen auf dem Laufenden.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Gibt es Preise zu gewinnen?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>BUDDYBET ist eine reine Spaß-Plattform ohne Geldgewinne. Der Preis ist der Ruhm und die Anerkennung
                deiner Tippgruppe! Manche Gruppen organisieren eigene kleine Belohnungen für die Gewinner - das bleibt
                aber euch überlassen.</p>
        </div>
    </div>
</section>

<section id="account" style="margin-bottom: 80px;">
    <h2>Account</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie ändere ich mein Passwort?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Gehe zu deinen Account-Einstellungen und klicke auf "Passwort ändern". Du benötigst dein aktuelles
                Passwort und musst das neue Passwort zweimal eingeben. Aus Sicherheitsgründen wirst du danach
                automatisch abgemeldet und musst dich neu anmelden.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Kann ich meinen Benutzernamen ändern?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Ja, du kannst deinen Benutzernamen in den Account-Einstellungen ändern. Beachte aber, dass andere
                Gruppenmitglieder dich dann möglicherweise nicht mehr sofort erkennen. Eine Änderung ist alle 30 Tage
                möglich.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie lösche ich meinen Account?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>In den Account-Einstellungen findest du unter "Account löschen" die entsprechende Option. Beachte, dass
                dabei alle deine Tipps und Gruppenmitgliedschaften unwiderruflich gelöscht werden. Wir senden dir eine
                Bestätigungs-E-Mail, bevor der Account endgültig gelöscht wird.</p>
        </div>
    </div>
</section>

<section id="technisches" style="margin-bottom: 80px;">
    <h2>Technisches</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Welche Browser werden unterstützt?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>BUDDYBET funktioniert optimal in allen modernen Browsern: Chrome, Firefox, Safari, Edge und Opera. Wir
                empfehlen, immer die neueste Version zu verwenden. Auf mobilen Geräten funktioniert die Webseite genauso
                gut wie am Desktop.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Gibt es eine mobile App?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Aktuell gibt es noch keine native App, aber unsere Webseite ist vollständig mobiloptimiert. Du kannst
                BUDDYBET als Web-App zu deinem Homescreen hinzufügen und sie wie eine normale App nutzen. Eine native
                App ist für die Zukunft geplant!</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Warum werden manche Spielergebnisse nicht angezeigt?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Wir beziehen unsere Spielergebnisse von zuverlässigen Datenquellen, aber manchmal kann es zu
                Verzögerungen kommen. Falls ein Ergebnis länger als eine Stunde nach Spielende fehlt, melde es uns bitte
                über den Support.</p>
        </div>
    </div>
</section>

<section id="sicherheit" style="margin-bottom: 80px;">
    <h2>Sicherheit</h2>

    <div class="faq-item">
        <div class="faq-question">
            <span>Wie sicher sind meine Daten?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Deine Daten sind bei uns sicher! Wir verwenden moderne Verschlüsselungstechnologien, speichern Passwörter
                gehasht und befolgen die DSGVO-Richtlinien. Wir verkaufen keine Daten und zeigen keine personalisierte
                Werbung.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Was tut ihr gegen Spam und Missbrauch?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Wir haben ein Moderationssystem und Community-Richtlinien. Nutzer können problematische Inhalte melden,
                und wir reagieren schnell auf Beschwerden. Wiederholte Verstöße führen zu Verwarnungen oder
                Account-Sperrungen.</p>
        </div>
    </div>

    <div class="faq-item">
        <div class="faq-question">
            <span>Kann ich meine Privatsphäre-Einstellungen anpassen?</span>
            <i class="bi bi-chevron-down"></i>
        </div>
        <div class="faq-answer">
            <p>Ja! In deinen Account-Einstellungen kannst du festlegen, wer dein Profil sehen kann, ob du in
                öffentlichen Ranglisten erscheinst und welche Benachrichtigungen du erhalten möchtest. Du hast die volle
                Kontrolle über deine Sichtbarkeit.</p>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section class="how-it-works">
    <div class="steps">
        <h2>Weitere Fragen?</h2>
        <p>Wir helfen dir gerne weiter!</p>

        <div class="step">
            <div class="step-number">
                <i class="bi bi-envelope-fill"></i>
            </div>
            <div class="step-content">
                <h3>E-Mail Support</h3>
                <p>Schreibe uns eine E-Mail an <strong>support@buddybet.de</strong> - wir antworten meist innerhalb von
                    24 Stunden.</p>
            </div>
        </div>

        <div class="step">
            <div class="step-number">
                <i class="bi bi-chat-dots-fill"></i>
            </div>
            <div class="step-content">
                <h3>Community</h3>
                <p>Tausche dich mit anderen Nutzern in unserer Community aus oder folge uns auf Social Media.</p>
            </div>
        </div>
    </div>
</section>
<style>
    /* FAQ Styles */
    .faq-item {
        background-color: var(--color-blue-p8);
        border-radius: 8px;
        margin-bottom: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .faq-item:hover {
        transform: translateY(-2px);
    }

    .faq-question {
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .faq-question span {
        font-size: 18px;
        font-weight: 400;
        color: var(--color-text-primary);
        flex: 1;
    }

    .faq-question i {
        color: var(--color-green-base);
        font-size: 20px;
        transition: transform 0.3s ease;
    }

    .faq-item.active .faq-question i {
        transform: rotate(180deg);
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: all 0.3s ease;
        background-color: var(--color-blue-p8);
    }

    .faq-item.active .faq-answer {
        max-height: 200px;
        padding: 20px 24px;
    }

    .faq-answer p {
        margin: 0;
        font-size: 16px;
        line-height: 24px;
        color: var(--color-white-m16);
    }
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
    // FAQ Accordion Funktionalität
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');

        question.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            // Close all FAQ items
            faqItems.forEach(otherItem => {
                otherItem.classList.remove('active');
            });

            // Open clicked item if it wasn't active
            if (!isActive) {
                item.classList.add('active');
            }
        });
    });

    // FAQ-interne Navigation (nur für Links die mit # beginnen und auf FAQ-Sectionen zeigen)
    const faqNavigationLinks = document.querySelectorAll('a[href^="#"]:not(.sidebar a)');

    faqNavigationLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            const targetId = link.getAttribute('href');
            const targetSection = document.querySelector(targetId);
            
            // Nur wenn das Ziel eine FAQ-Section ist
            if (targetSection && targetSection.tagName === 'SECTION') {
                e.preventDefault();
                targetSection.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });

    // Highlight aktive FAQ-Section beim Scrollen (nur wenn FAQ-Sectionen existieren)
    const faqSections = document.querySelectorAll('section[id]');
    
    if (faqSections.length > 0) {
        window.addEventListener('scroll', () => {
            let current = '';

            faqSections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (window.pageYOffset >= sectionTop - 200) {
                    current = section.getAttribute('id');
                }
            });

            // Nur FAQ-interne Navigation-Links updaten, nicht Sidebar-Links
            const faqNavLinks = document.querySelectorAll('a[href^="#"]:not(.sidebar a)');
            faqNavLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                }
            });
        });
    }
});
</script>