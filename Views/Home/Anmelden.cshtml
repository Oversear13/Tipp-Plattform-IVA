@{
    ViewData["Title"] = "Login & Registrieren";
}
@model AnmeldenViewModel

<section class="hero">
    <h1>Tippe mit Freunden. <span class="text-green">Gewinne zusammen.</span></h1>
    <p class="hero-subtitle">Erstelle deine eigene Tippgruppe, lade Freunde ein und tippe auf Sportereignisse.</p>
</section>

<section class="features">
    <div class="feature-card">
        <div class="feature-content">
            <h2 class="feature-title">Tippgruppen erstellen</h2>
            <p class="feature-text">Gründe deine eigene Tippgruppe und lade Freunde, Familie oder Kollegen ein. Bestimme die Regeln und werde zum Tippkönig!</p>
        </div>
        <div class="feature-icon">
            <i class="bi bi-people-fill"></i>
        </div>
    </div>

    <div class="feature-card">
        <div class="feature-content">
            <h2 class="feature-title">Alle Sportereignisse</h2>
            <p class="feature-text">Tippe auf alle wichtigen Fußball-Ligen, Turniere und andere Sportarten. Wir aktualisieren die Ergebnisse in Echtzeit.</p>
        </div>
        <div class="feature-icon">
            <i class="bi bi-trophy-fill"></i>
        </div>
    </div>

    <div class="feature-card">
        <div class="feature-content">
            <h2 class="feature-title">Benachrichtigungen</h2>
            <p class="feature-text">Erhalte Erinnerungen für anstehende Spiele und verpasse nie wieder einen Tipp. Werde über neue Ergebnisse sofort informiert.</p>
        </div>
        <div class="feature-icon">
            <i class="bi bi-bell-fill"></i>
        </div>
    </div>

    <div class="feature-card">
        <div class="feature-content">
            <h2 class="feature-title">Kostenlos & Sicher</h2>
            <p class="feature-text">Erlebe Tippfreude ohne Geldeinsätze. Bleibe frei von Spielsuchtrisiken - nur gesunder Wettkampf!</p>
        </div>
        <div class="feature-icon">
            <i class="bi bi-shield-fill-check"></i>
        </div>
    </div>
</section>

<section class="how-it-works">
    <div class="illustration">
        <img src="~/buddybet image.png" alt="BUDDYBET Plattform Image" />
    </div>

    <div class="steps">
        <h2>So funktioniert's</h2>
        <p>In drei einfachen Schritten zur BUDDYBET</p>
        
        <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
                <h3>Registrieren</h3>
                <p>Erstelle deinen Account in wenigen Sekunden</p>
            </div>
        </div>
        
        <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
                <h3>Tippgruppe erstellen oder beitreten</h3>
                <p>Gründe deine eigene Tippgruppe oder tritt einer existierenden Gruppe bei</p>
            </div>
        </div>
        
        <div class="step">
            <div class="step-number">3</div>
            <div class="step-content">
                <h3>Tippen und gewinnen</h3>
                <p>Gib deine Tipps ab, verfolge die Ergebnisse und steige in der Rangliste auf</p>
            </div>
        </div>
    </div>
</section>

<section class="auth-container" id="auth-container">
    <div class="form-container">
        <form asp-controller="Home" asp-action="Anmelden" method="post" class="register-form">
            <h1>Registrieren</h1>
            <div class="validation-summary">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>
            <div class="form-field">
                <label asp-for="Username" class="form-label">Benutzername*</label>
                <div class="input">
                    <input asp-for="Username" type="text" class="form-control" required />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="form-field">
                <label asp-for="Password" class="form-label">Passwort*</label>
                <div class="input">
                    <input asp-for="Password" type="password" class="form-control" required />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-field">
                <label asp-for="Email" class="form-label">E-Mail*</label>
                <div class="input">
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
            </div>
            <div class="form-field" style="margin-bottom: 36px;">
                <label asp-for="Geburtsdatum" class="form-label">Geburtsdatum*</label>
                <div class="input">
                    <input asp-for="Geburtsdatum" type="date" class="form-control" min="1925-01-01" max="3000-12-31" required/>
                </div>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Jetzt registrieren</button>
        </form>
    </div>
    <div class="welcome-back">
        <h1>Hello, <span class="text-green"> Buddy!</span></h1>
        <p>Hast du schon ein Konto? Melden dich an, um mit deiner Gruppe in Verbindung zu bleiben.</p>
        <a href="/Home/Login#auth-container" class="btn btn-outline" style="width: 100%;">Anmelden</a>
    </div>
</section>