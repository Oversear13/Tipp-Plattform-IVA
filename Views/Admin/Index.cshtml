@{
    ViewData["Title"] = "Admin Dashboard";
}
@model AdminViewModel

<h1>Admin Dashboard</h1>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h4 class="mb-3">Bevorstehende Spiele (@Model.BevorstehendeSpiele.Count())</h4>
            <form method="post" asp-action="SaveMatchesToDatabase">
                <div class="d-flex align-items-center gap-2">
                    <button type="submit" name="Mode" value="InsertNew" class="btn btn-primary">Spiele
                        importieren</button>
                    <input class="form-control w-auto" asp-for="Date" type="date" />
                </div>
            </form>
            <div class="overflow-auto" style="max-height: 300px;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Spiel</th>
                            <th>Datum</th>
                        </tr>
                    </thead>
                    <tbody>
                            @foreach (var match in Model.BevorstehendeSpiele)
                            {
                                <tr>
                                    <td>@match.Id</td>
                                    <td>@match.TeamA.Name @match.TeamB.Name</td>
                                    <td>@match.SpielBeginn?.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <h4 class="mb3">Ausstehende Spielergebnisse (@Model.AusstehendeSpielergebnisse.Count())</h4>
            <form method="post" asp-action="SaveMatchesToDatabase">
                <div class="d-flex align-items-center gap-2">
                    <button type="submit" name="Mode" value="UpdateExisting" class="btn btn-primary">Ergebnisse
                        importieren</button>
                    <input class="form-control w-auto" asp-for="Date" type="date" />
                </div>
            </form>
            <div class="overflow-auto" style="max-height: 300px;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Spiel</th>
                            <th>Datum</th>
                            <th>Ergebnis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AusstehendeSpielergebnisse == null || !Model.AusstehendeSpielergebnisse.Any())
                        {
                            <tr>
                                <td colspan="5">
                                    Es gibt noch keine Ausstehende Spielergebnisse. Du kannst die Ergebnisse importieren.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var match in Model.AusstehendeSpielergebnisse)
                            {
                                <tr>
                                    <td>@match.Id</td>
                                    <td>@match.TeamA.Name @match.TeamB.Name</td>
                                    <td>@match.SpielBeginn?.ToString("dd.MM.yyyy")</td>
                                    <td>-</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h4 class="mb-3">Spielergebnisse (@Model.Spielergebnisse.Count())</h4>
            <div class="overflow-auto" style="max-height: 300px;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Spiel</th>
                            <th>Datum</th>
                            <th>Ergebnis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Spielergebnisse == null || !Model.Spielergebnisse.Any())
                        {
                            <tr>
                                <td colspan="5">
                                    Es gibt Noch keine Spielergebnisse.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var match in Model.Spielergebnisse)
                            {
                                <tr>
                                    <td>@match.Id</td>
                                    <td>@match.TeamA.Name @match.TeamB.Name</td>
                                    <td>@match.SpielBeginn?.ToString("dd.MM.yyyy")</td>
                                    <td>@match.TeamAScore - @match.TeamBScore</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
