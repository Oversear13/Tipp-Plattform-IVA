<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BUDDYBET</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Titillium+Web:wght@300;400;600;700&display=swap">

    <!-- CSS-Dateien -->
    <link rel="stylesheet" href="~/css/colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/btn.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/input.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/table.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navtabs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TippPlattform.styles.css" asp-append-version="true" />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- DataTables CSS (Bootstrap 5) -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>


    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="home-page">
    <header>
        <div class="logo">BUDDY<span>BET</span></div>
        <nav>
            <ul>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Index"
                        class="@(ViewContext.RouteData.Values["Controller"].ToString() == "Home" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                        Home</a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="AboutUs"
                        class="@(ViewContext.RouteData.Values["Controller"].ToString() == "Home" && ViewContext.RouteData.Values["Action"].ToString() == "AboutUs" ? "active" : "")">
                        Über uns</a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Fragen"
                        class="@(ViewContext.RouteData.Values["Controller"].ToString() == "Home" && ViewContext.RouteData.Values["Action"].ToString() == "Fragen" ? "active" : "")">
                        FAQ</a>
                </li>
            </ul>
        </nav>
        <div class="auth-buttons">
            @if (User.Identity.IsAuthenticated)
            {
                <!-- Profile dropdown -->
                <div class="dropdown" style="position: fixed; top: 24px; right: 24px; z-index: 1050;">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">

                        @{
                            var username = User.Identity?.Name ?? "U";
                            var initial = !string.IsNullOrEmpty(username) ? username.Substring(0, 1).ToUpper() : "U";

                            var userId = User.FindFirst("UserId")?.Value;
                            var hasUnread = false;

                            if (!string.IsNullOrEmpty(userId))
                            {
                                using (var scope = Context.RequestServices.CreateScope())
                                {
                                    var db = scope.ServiceProvider.GetRequiredService<TippPlattformContext>();
                                    hasUnread = db.Nachrichten.Any(n => n.EmpfaengerId.ToString() == userId && n.GelesenDatum == null);
                                }
                            }
                        }
                        <div style="position: relative;">
                            <div style="padding: 0 24px; height: 40px; background-color: var(--color-blue-p32); color: var(--color-white-base); border-radius: 4px; box-shadow: var(--shadow-md); display: flex; align-items: center; justify-content: center; font-weight: 300; font-size: 18px; position: relative; user-select: none;">
                                <i class="bi bi-person-circle" style="margin-right: 8px;"></i>
                                @User.Identity.Name
                                <i class="bi bi-chevron-down" style="font-size: 14px; margin-left: 24px;"></i>
                            </div>
                            @if (hasUnread)
                            {
                                <!-- Notification dot -->
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                    <span class="visually-hidden">Neue Nachrichten</span>
                                </span>
                            }
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end mt-2" aria-labelledby="profileDropdown" style="min-width: 200px;">
                        <li><a class="dropdown-item" href="/User/MeinProfil">Mein Profil</a></li>
                        <li>
                            <a class="dropdown-item position-relative" href="/Nachrichten">
                                Nachrichten
                                @if (hasUnread)
                                {
                                    <!-- Notification dot -->
                                    <span style="position: absolute; top: 8px; left: 95%; transform: translate(-50%, -50%); padding: 5px; background-color: red; border: 2px solid white; border-radius: 50%;"></span>
                                }
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Home/Logout">Logout</a></li>
                    </ul>

                </div>
            }
            else
            {
                <a asp-area="" asp-controller="Home" asp-action="Login" asp-fragment="auth-container"
                    class="btn btn-primary"><i class="bi bi-box-arrow-in-right"></i>Anmelden</a>
                <a asp-area="" asp-controller="Home" asp-action="Anmelden" asp-fragment="auth-container"
                    class="btn btn-outline"><i class="bi bi-person-plus"></i>Registrieren</a>
            }
        </div>
    </header>

    <div class="page-container">
        @if (User.Identity.IsAuthenticated)
        {
            <aside class="sidebar" id="sidebar">
                <nav class="d-flex flex-column h-100">
                    <div class="nav-item">
                        <a asp-area="" asp-controller="Home" asp-action="Index"
                            class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">Startseite</a>
                    </div>
                    <div class="nav-item">
                        <a asp-area="" asp-controller="TippGruppen" asp-action="Index"
                            class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "TippGruppen" ? "active" : "")">Tippgruppen</a>
                    </div>
                    <div class="nav-item">
                        <a asp-area="" asp-controller="User" asp-action="MeinProfil"
                           class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "User" && ViewContext.RouteData.Values["Action"].ToString() == "MeinProfil" ? "active" : "")">
                            Mein Profil
                        </a>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-item">
                            <a asp-area="" asp-controller="Admin" asp-action="SpieleListe"
                                class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Admin" && ViewContext.RouteData.Values["Action"].ToString() == "SpieleListe" ? "active" : "")">Spiele
                                (admin)</a>
                        </div>
                        <div class="nav-item">
                            <a asp-area="" asp-controller="Admin" asp-action="TippgruppenListe"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Admin" && ViewContext.RouteData.Values["Action"].ToString() == "TippgruppenListe" ? "active" : "")">
                                Tippgruppen (admin)
                            </a>
                        </div>
                        <div class="nav-item">
                            <a asp-area="" asp-controller="Admin" asp-action="UserListe"
                                class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Admin" && ViewContext.RouteData.Values["Action"].ToString() == "UserListe" ? "active" : "")">Nutzer
                                (admin)</a>
                        </div>
                        <div class="nav-item">
                            <a asp-area="" asp-controller="Admin" asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Admin" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                                Spiele-Import
                                (admin)
                            </a>
                        </div>
                    }
                </nav>
            </aside>
        }

        <div class="content-wrapper">
            <main role="main">
                @RenderBody()
            </main>
            <footer>
                <div class="footer-content">
                    <div class="footer-section">
                        <div class="footer-illustration">
                            <img src="~/logo.png" alt="BUDDYBET Logo" />
                        </div>
                    </div>

                    <div class="footer-section">
                        <h3>Unternehmen</h3>
                        <ul>
                            <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="AboutUs">Über uns</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Fragen">FAQ</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="AboutUs" asp-fragment="contact">Kontakt</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h3>Unsere Apps</h3>
                        <ul>
                            <li><a href="#">Android App</a></li>
                        </ul>
                    </div>

                    <div class="footer-section">
                        <h3>Unsere Partner</h3>
                        <div class="partner-logos">
                            <div class="logo-item">
                                <img src="~/PayBuddy_logo.png" alt="PayBuddy Partner Logo" />
                            </div>
                            <div class="logo-item">
                                <img src="~/MercedesBET_logo.png" alt="MercedesBET Partner Logo" />
                            </div>
                            <div class="logo-item">
                                <img src="~/BetCoin_logo.png" alt="BETCoin Partner Logo" />
                            </div>
                            <div class="logo-item">
                                <img src="~/TeleBuddy_logo.png" alt="TeleBuddy Partner Logo" />
                            </div>
                        </div>
                    </div>

                    <div class="footer-section">
                        <h3>Rechtliches</h3>
                        <ul>
                            <li><a asp-area="" asp-controller="Home" asp-action="Agb">AGB</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Impressum">Impressum</a></li>
                            <li><a asp-area="" asp-controller="Home" asp-action="Datenschutz">Datenschutz</a></li>
                        </ul>
                    </div>
                </div>

                <div class="copyright">
                    &copy; @DateTime.Now.Year BUDDYBET. Alle Rechte vorbehalten.
                </div>
            </footer>
        </div>
    </div>

    <!-- JavaScript-->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- jQuery Validation Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>

</html>